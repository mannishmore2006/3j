datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // "Employee" | "HR" | "Admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  employee  Employee?
}

model Employee {
  id             String       @id
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  department     String
  avatarInitials String
  status         String       @default("Active") // "Active" | "On Leave" | "Suspended"
  joinDate       String
  deviceToken    String?
  createdAt      DateTime     @default(now())
  attendance     Attendance[]
  leaves         Leave[]
}

model Attendance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        String   // YYYY-MM-DD
  checkIn     String   // HH:MM AM/PM or "--:--"
  checkOut    String?  // HH:MM AM/PM
  status      String   // "Present" | "Late" | "Absent" | "On Leave"
  coordinates String?  // GPS coordinates e.g., "37.7749° N, 122.4194° W"
  createdAt   DateTime @default(now())

  @@unique([employeeId, date])
}

model Leave {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String   // "Paid Leave" | "Sick Leave" | "Unpaid Leave" | "Casual Leave"
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  reason     String
  status     String   @default("Pending") // "Pending" | "Approved" | "Rejected"
  appliedOn  String   // YYYY-MM-DD
  createdAt  DateTime @default(now())
}

model Holiday {
  id   String @id @default(uuid())
  name String
  date String // YYYY-MM-DD
  day  String
}
